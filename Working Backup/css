/* Optional: smooth transitions */
.fco-sticker__arc-text,
.fco-sticker__price-text {
  font-weight: bold;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.fco-sticker__arc-text {
  font-size: 9px;
  fill: var(--color-scheme-text, #43362f);
  letter-spacing: 1px;
}

.fco-sticker__price-text {
  font-size: 3em;
  fill: rgb(var(--color-secondary-background));
  font-family: 'HeadingNow-96Bold';
  transform-box: fill-box;
  transform-origin: center;
  transition: transform 0.3s ease;
}

div#promoDetailsPanel,
.fco-banner__promo-details {
  display: flex;
  flex-direction: column;
  flex-wrap: wrap;
  gap: 2em;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  margin-top: 0;
  transform: translateY(-4px);
  pointer-events: none;
  transition: max-height 0.35s ease, opacity 0.25s ease, transform 0.25s ease, margin-top 0.25s ease;
}

div#promoDetailsPanel.is-open,
.fco-banner__promo-details.is-open {
  max-height: 420px;
  opacity: 1;
  margin-top: 10px;
  transform: translateY(0);
  pointer-events: auto;
}

.fco-banner #promoCode {
    padding: 1em;
    background:  rgb(var(--color-secondary-background));
    color: var(--fco-banner-color-black);
    border-radius: .6em;
    border: 1px dashed;
    transition: all  0.3s ease;
}

.fco-banner #promoCode:hover {
    padding: 1em;
    background: rgb(var(--color-secondary-background) / 60%);
    color: var(--fco-banner-color-black);
    border-radius: .6em;
    border: 1px dashed;
}

.fco-price-original {
  text-decoration: line-through;
  opacity: 0.72;
  margin-right: 0.5rem;
}

.fco-price-promo {
  display: inline-block;
  color: var(--fco-sticker-color, #D9391F);
  font-weight: 700;
  vertical-align: baseline;
}
