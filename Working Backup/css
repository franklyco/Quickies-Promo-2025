/* Optional: smooth transitions */
.fco-sticker__arc-text,
.fco-sticker__price-text {
  font-family: sans-serif;
  font-weight: bold;
  fill: #000;
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.fco-sticker__arc-text {
  font-size: 9px;
}

.fco-sticker__price-text {
  font-size: xx-large;
  transform-box: fill-box;
  transform-origin: center;
  transition: transform 0.3s ease;
}

.fco-banner #promoCode {
    padding: 0.5em;
    background: #d8d8d8;
    color: #000000;
    border-radius: 0.6em;
    border: 1px dashed;
}



